# Copy to `.env` in this folder (same values as apps/web-app/.env.local, with EXPO_PUBLIC_ prefix).
# Restart Metro after changes: npx expo start -c

EXPO_PUBLIC_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=

EXPO_PUBLIC_APPWRITE_DATABASE_ID=
EXPO_PUBLIC_APPWRITE_PARENTS_TABLE=parents
EXPO_PUBLIC_APPWRITE_DRIVERS_TABLE=drivers
EXPO_PUBLIC_APPWRITE_VEHICLES_TABLE=vehicles
EXPO_PUBLIC_APPWRITE_VEHICLE_DRIVERS_TABLE=vehicle_drivers
EXPO_PUBLIC_APPWRITE_PARENT_STUDENTS_TABLE=parent_student
EXPO_PUBLIC_APPWRITE_TRANSPORT_SESSIONS_TABLE=transport_sessions
EXPO_PUBLIC_APPWRITE_SESSION_STUDENTS_TABLE=session_students
EXPO_PUBLIC_APPWRITE_STUDENT_STUDENT_TABLE=students
EXPO_PUBLIC_APPWRITE_GPS_TRACKING_TABLE=gps_tracking
EXPO_PUBLIC_APPWRITE_NOTIFICATIONS_TABLE=notifications
EXPO_PUBLIC_APPWRITE_PUSH_TOKENS_TABLE=push_tokens
# Authoritative role table (must match the web app).
EXPO_PUBLIC_APPWRITE_USERS_TABLE=users

# Admin API for parent notifications (driver → Next.js with APPWRITE_API_KEY).
# Use localhost here; in dev the app rewrites it per platform (10.0.2.2 on Android emulator, LAN IP on device).
# Requires: npm run web (listens on 0.0.0.0:3000) while testing attendance notifications.
EXPO_PUBLIC_WEB_API_URL=http://localhost:3000

# Optional: Expo push (EAS project id for production push tokens)
EXPO_PUBLIC_EAS_PROJECT_ID=

# Optional: Mapbox token (reserved for future native Mapbox tiles)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

EXPO_PUBLIC_APPWRITE_GT_SESSION_REL=transportSessionId
EXPO_PUBLIC_APPWRITE_GT_VEHICLE_REL=vehicleId
EXPO_PUBLIC_APPWRITE_GT_DRIVER_REL=driverId

EXPO_PUBLIC_APPWRITE_PS_PARENT_REL=parentId
EXPO_PUBLIC_APPWRITE_PS_STUDENT_REL=studentId

EXPO_PUBLIC_APPWRITE_N_PARENT_REL=parentId
EXPO_PUBLIC_APPWRITE_N_STUDENT_REL=studentId
EXPO_PUBLIC_APPWRITE_N_SESSION_REL=transportSessionId

EXPO_PUBLIC_APPWRITE_PT_PARENT_REL=parentId

EXPO_PUBLIC_APPWRITE_VD_VEHICLE_REL=vehicleId
EXPO_PUBLIC_APPWRITE_VD_DRIVER_REL=driverId
EXPO_PUBLIC_APPWRITE_TS_VEHICLE_REL=vehicleId
EXPO_PUBLIC_APPWRITE_TS_DRIVER_REL=driverId
EXPO_PUBLIC_APPWRITE_SS_SESSION_REL=transportSessionId
EXPO_PUBLIC_APPWRITE_SS_STUDENT_REL=studentId
