# Copy to `.env.local` and fill in your Appwrite project values.

# Server-only (never expose to the browser). Required for driver/parent provisioning.
# Create in Appwrite Console → API Keys → scopes: users.read, users.write
APPWRITE_API_KEY=

# Optional overrides (defaults to NEXT_PUBLIC_* below)
# APPWRITE_ENDPOINT=
# APPWRITE_PROJECT_ID=

NEXT_PUBLIC_APPWRITE_PROJECT_ID=
NEXT_PUBLIC_APPWRITE_PROJECT_NAME=school-transport
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1

NEXT_PUBLIC_APPWRITE_DATABASE_ID=
NEXT_PUBLIC_APPWRITE_PARENT_STUDENTS_TABLE=parent_students
NEXT_PUBLIC_APPWRITE_STUDENT_STUDENT_TABLE=students
NEXT_PUBLIC_APPWRITE_STUDENT_PARENT_TABLE=parents
NEXT_PUBLIC_APPWRITE_DRIVERS_TABLE=drivers
NEXT_PUBLIC_APPWRITE_VEHICLES_TABLE=vehicles
NEXT_PUBLIC_APPWRITE_VEHICLE_STUDENTS_TABLE=vehicle_students
NEXT_PUBLIC_APPWRITE_VEHICLE_DRIVERS_TABLE=vehicle_drivers
NEXT_PUBLIC_APPWRITE_TRANSPORT_SESSIONS_TABLE=transport_sessions
NEXT_PUBLIC_APPWRITE_SESSION_STUDENTS_TABLE=session_students
NEXT_PUBLIC_APPWRITE_GPS_TRACKING_TABLE=gps_tracking
NEXT_PUBLIC_APPWRITE_NOTIFICATIONS_TABLE=notifications

# Authoritative role table. Attributes: appwriteUserId, role (admin|driver|parent),
# status (active|inactive), createdAt, updatedAt.
NEXT_PUBLIC_APPWRITE_USERS_TABLE=users

# Bootstrap admins (comma-separated Appwrite user IDs). Used ONLY when the user
# has no row in the `users` table yet; useful for seeding the first admin.
# Recommended: leave empty in production and create explicit `users` rows instead.
ADMIN_APPWRITE_USER_IDS=

# Mapbox (live admin map)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Relationship column keys on `gps_tracking`
NEXT_PUBLIC_APPWRITE_GT_SESSION_REL=transportSessionId
NEXT_PUBLIC_APPWRITE_GT_VEHICLE_REL=vehicleId
NEXT_PUBLIC_APPWRITE_GT_DRIVER_REL=driverId


# Relationship column keys on `parent_students` (must match Appwrite Console → Columns)
# Relationship column keys on `parent_student` (values = parents.$id / students.$id)
NEXT_PUBLIC_APPWRITE_PS_PARENT_REL=parentId
NEXT_PUBLIC_APPWRITE_PS_STUDENT_REL=studentId

# Relationship column keys on `vehicle_students`
NEXT_PUBLIC_APPWRITE_VS_VEHICLE_REL=vehicleId
NEXT_PUBLIC_APPWRITE_VS_STUDENT_REL=studentId

# Relationship column keys on `vehicle_drivers`
NEXT_PUBLIC_APPWRITE_VD_VEHICLE_REL=vehicleId
NEXT_PUBLIC_APPWRITE_VD_DRIVER_REL=driverId

# Relationship column keys on `transport_sessions`
NEXT_PUBLIC_APPWRITE_TS_VEHICLE_REL=vehicleId
NEXT_PUBLIC_APPWRITE_TS_DRIVER_REL=driverId

# Relationship column keys on `session_students`
NEXT_PUBLIC_APPWRITE_SS_SESSION_REL=transportSessionId
NEXT_PUBLIC_APPWRITE_SS_STUDENT_REL=studentId

# Relationship column keys on `gps_tracking`
NEXT_PUBLIC_APPWRITE_GT_SESSION_REL=transportSessionId
NEXT_PUBLIC_APPWRITE_GT_VEHICLE_REL=vehicleId
NEXT_PUBLIC_APPWRITE_GT_DRIVER_REL=driverId

# Mapbox (live tracking map)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional: storage bucket for student photos
NEXT_PUBLIC_APPWRITE_STORAGE_BUCKET_ID=
